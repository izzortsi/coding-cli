# Anthropic API key (alternative to OAuth)
# ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# z.ai API key
# ZHIPU_API_KEY=your-api-key-here
# ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# LM Studio local server (optional)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_DEBUG=1

# Ollama local server (optional, auto-detected)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEBUG=1

# Optional: data directory (default: ~/.coding-cli)
# CODING_CLI_DATA_DIR=~/.coding-cli

# Optional: enable audio feedback
# CODING_CLI_SOUNDS=1

# Editor for /edit command and Ctrl+X E keybinding
# EDITOR=nvim
# VISUAL=nvim
